unsigned int mouse_bg_buffer[64];  

void draw_mouse_cursor(int x, int y) {
    uint32_t color;
    for (int i = 0; i < 8; i++) {
        for (int j = 0; j < 8; j++) {
            int px = x + j;
            int py = y + i;

             
            if (px >= 0 && (uint32_t)px < MAX_COLS_PIXELS && py >= 0 && (uint32_t)py < MAX_HEIGHT) {
                
                 
                mouse_bg_buffer[i * 8 + j] = GOP_FRAMEBUFFER[py * GOP_PIXELS_PER_SCANLINE + px];

                 
                if (cursor_mask[i][j] == 1) {
                    color = 0xFFFFFFFF;  
                    GOP_FRAMEBUFFER[py * GOP_PIXELS_PER_SCANLINE + px] = color;
                } 
                else if (cursor_mask[i][j] == 2) {
                    color = 0x00000000;  
                    GOP_FRAMEBUFFER[py * GOP_PIXELS_PER_SCANLINE + px] = color;
                }
                 
            }
        }
    }
}
 


void handle_ps2_mouse() {
    while (inb(0x64) & 0x01) {  
        uint8_t data = inb(0x60);
        if (mouse_phase == 0 && !(data & 0x08)) continue;  

        mouse_data[mouse_phase++] = data;

        if (mouse_phase == 3) {
            mouse_phase = 0;
            
             
            clear_mouse_cursor(mouse_x, mouse_y);

            int8_t rel_x = (int8_t)mouse_data[1];
            int8_t rel_y = (int8_t)mouse_data[2];

            mouse_x += rel_x;
            mouse_y -= rel_y; 

             
            if (mouse_x < 0) mouse_x = 0;
            if (mouse_y < 0) mouse_y = 0;
            if (mouse_x > (int)MAX_COLS_PIXELS - 8) mouse_x = MAX_COLS_PIXELS - 8;
            if (mouse_y > (int)MAX_HEIGHT - 8) mouse_y = MAX_HEIGHT - 8;

             
            draw_mouse_cursor(mouse_x, mouse_y);
        }
    }
}
}
void clear_mouse_cursor(int x, int y) {
    for (int i = 0; i < 8; i++) {
        for (int j = 0; j < 8; j++) {
            int px = x + j;
            int py = y + i;
            if (px >= 0 && px < MAX_COLS_PIXELS && py >= 0 && py < MAX_HEIGHT) {
                GOP_FRAMEBUFFER[py * GOP_PIXELS_PER_SCANLINE + px] = mouse_bg_buffer[i * 8 + j];
            }
        }
    }
}
